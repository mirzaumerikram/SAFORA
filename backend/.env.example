# ============================================================
#  SAFORA — Environment Variables Template
#  Copy this file: cp .env.example .env
#  Then fill in your actual values
# ============================================================

PORT=5000
NODE_ENV=development

# MongoDB Atlas — get from Atlas dashboard
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/safora?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRE=7d

# Firebase — Firebase Console > Project Settings > Web App config
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id

# Gmail SMTP — use App Password, not your Gmail password
# myaccount.google.com > Security > App passwords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Your PC local IP for email verification links
APP_BASE_URL=http://192.168.x.x:5000

# Stripe test keys — dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# AI microservice
AI_SERVICE_URL=http://localhost:5001
