# Google Maps API Configuration
# ================================
# Get your API key from: https://console.cloud.google.com/
# 
# Required APIs:
# 1. Maps JavaScript API (for web maps)
# 2. Places API (for location autocomplete)
# 3. Geocoding API (for address to coordinates conversion)
# 4. Maps SDK for Android (for native Android)
# 5. Maps SDK for iOS (for native iOS)

# For Expo (React Native Web/Mobile)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# For backend (if needed)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration (if using)
FIREBASE_API_KEY=your_firebase_key
FIREBASE_AUTH_DOMAIN=your_firebase_domain
FIREBASE_PROJECT_ID=your_firebase_project

# Backend API Base URL
REACT_APP_API_BASE_URL=http://localhost:5000/api

# Socket.io Server URL
REACT_APP_SOCKET_URL=http://localhost:5000
